022 FIFA World Cup, however he was not included in the final 26-man squad.\r\n\r\nOn 12 October 2023, Piotrowski made his debut for the senior team against the Faroe Islands during a UEFA Euro 2024 qualifying match, a 2–0 victory.\r\n\r\nOn 7 June 2024, he was named in Poland's squad for UEFA Euro 2024.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"","strPosition":"Midfielder","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"","strYoutube":"","strHeight":"1.87 m (6 ft 1 in)","strWeight":"172 lbs","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/pb40gc1719012263.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/pajueo1764172535.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/eq8t0y1719012351.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"Yes","strLocked":"unlocked","strLastName":"Piotrowski"},{"idPlayer":"34176094","idTeam":"133679","idTeam2":"133916","idTeamNational":null,"idAPIfootball":"48047","idPlayerManager":null,"idWikidata":null,"idTransferMkt":"222855","idESPN":"237055","strNationality":"Sweden","strPlayer":"Jesper Karlström","strPlayerAlternate":"","strTeam":"Udinese","strTeam2":"Sweden","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"1995-06-21","dateDied":null,"strNumber":"8","dateSigned":null,"strSigning":"","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"Stockholm, Sweden","strEthnicity":"","strStatus":"Active","strDescriptionEN":"Jesper Kewe Karlström (born 21 June 1995) is a Swedish professional footballer who plays as a midfielder for Serie A club Udinese and the Sweden national team.\r\n\r\nKarlström has represented Sweden at the U17, U19 and U21 levels. In November 2014 he made his debut for the Sweden national under-21 football team against Austria.\r\n\r\nHe made his full international debut for the Sweden national team on 11 January 2018 in a friendly 1–0 win against Denmark, playing for 66 minutes before being replaced by Kristoffer Olsson.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"","strPosition":"Defensive Midfield","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"www.instagram.com/jesperkarlstrom/","strYoutube":"","strHeight":"185 cm","strWeight":"179 lbs","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/5zowmu1648636205.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/r1owct1764172392.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/gqvvrg1648636258.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Karlström"}]}