ps://r2.thesportsdb.com/images/media/player/cutout/hvd5tq1762288248.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/6his811610363321.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Rrahmani"},{"idPlayer":"34163809","idTeam":"133670","idTeam2":"134498","idTeamNational":null,"idAPIfootball":"3406","idPlayerManager":null,"idWikidata":"Q21039587","idTransferMkt":null,"idESPN":"215721","strNationality":"Cameroon","strPlayer":"Andre-Frank Zambo Anguissa","strPlayerAlternate":"","strTeam":"Napoli","strTeam2":"Cameroon","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"1995-11-16","dateDied":null,"strNumber":"99","dateSigned":null,"strSigning":"on loan (Fulham)","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"Yaoundé, Cameroon","strEthnicity":"Black","strStatus":"Active","strDescriptionEN":"André-Frank Zambo Anguissa (born 16 November 1995) is a Cameroonian professional footballer who plays as a centre midfielder for La Liga club Villarreal CF on loan from English club Fulham and the Cameroonian national team.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":"André Frank Zambo Anguissa, noto semplicemente come Zambo Anguissa (Yaoundé, 16 novembre 1995), è un calciatore camerunese, centrocampista del Napoli, in prestito con diritto di riscatto dal Fulham, e della nazionale camerunese.","strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"Right","strPosition":"Midfielder","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"www.instagram.com/anguiss_29/","strYoutube":"","strHeight":"1.84 m (6 ft 0 in)","strWeight":"172 lbs","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/1iqml21534863544.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/bedkjv1762288303.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/h24k6s1631194839.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Anguissa"},{"idPlayer":"34170768","idTeam":"133670","idTeam2":null,"idTeamNational":null,"idAPIfootball":null,"idPlayerManager":null,"idWikidata":null,"idTransferMkt":null,"idESPN":null,"strNationality":"Italy","strPlayer":"Antonio Conte","strPlayerAlternate":"","strTeam":"Napoli","strTeam2":"","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"1969-07-31","dateDied":null,"strNumber":"","dateSigned":null,"strSigning":"","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"Lecce, Italy","strEthnicity":"White","strStatus":"","strDescriptionEN":"Antonio Conte Cavaliere OMRI (born 31 July 1969) is an Italian professional football manager and former player who is currently the head coach of Serie A club Napoli.\r\n\r\nPlaying as a midfielder, Conte began his career at local club Lecce and later became one of the most decorated and influential players in the history of Juventus having won, among others, five Serie A titles, one Coppa Italia, one UEFA Champions League and one UEFA Cup, becoming also the team's captain from 1996 until 2001. He also played for the Italy national team and was a participant at the 1994 FIFA World Cup and UEFA Euro 2000, where, on both occasions, Italy finished runners-up.\r\n\r\nHis managerial career started in 2006, leading Bari to a Serie B title, and Siena to promotion from the same division two years later. He took over at Juventus in 2011 and won three consecutive Serie A titles before taking charge of the Italy national team in 2014 until UEFA Euro 2016 where he led them to the quarter-finals. He then became Chelsea manager and led them to the Premier League title in his first season in charge, then winning the FA Cup in his second season but being dismissed as they finished fifth in the league. Conte joined Inter Milan a year later, leading the team to the UEFA Europa League final in his first season, then winning the 2020–21 Serie A title in his second season before stepping down in mutual consent. He joined Tottenham Hotspur in November 2021, but left in March 2023, by mutual consent.\r\n\r\nConte is credited with the repopularisation of the 3–5–2 formation after it had seen very limited use since its heyday at the 1990 World Cup.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":"Antonio Conte (Lecce, 31 luglio 1969) è un allenatore di calcio ed ex calciatore italiano, di ruolo centrocampista, tecnico dell'Inter.\r\n\r\nGiocatore combattivo e molto versatile tatticamente,[1] è cresciuto nel settore giovanile del Lecce, con cui ha esordito in Serie A e in cui ha militato per nove anni, per poi assurgere ad alti livelli nella Juventus, club di cui ha vestito la maglia per tredici anni a cavallo degli anni 1990 e 2000, diventandone capitano e simbolo in virtù della propria dedizione, tenacia e grinta.[2] In bianconero ha vinto cinque campionati di Serie A e tutte le competizioni UEFA tranne la Coppa delle Coppe, competizione cui non ha mai preso parte. Con la nazionale italiana è stato vicecampione del mondo nel 1994 e vicecampione d'Europa nel 2000.\r\n\r\nConsiderato uno degli allenatori più capaci in attività,[3][4][5] nel 2005 inizia la sua attività sulla panchina del Siena come vice di De Canio, e nella stagione 2008-09 ottiene il titolo di campione nel campionato cadetto con il Bari, riportando i pugliesi in Serie A. Passato sulla panchina della Juventus nell'estate 2011, si conferma campione d'Italia per tre stagioni consecutive (una striscia in precedenza riuscita ai soli Carcano, Capello e Mancini, e successivamente migliorata dal solo Allegri),[6] oltre ad avere vinto due Supercoppe italiane nel 2012 e nel 2013. Dal 2014 al 2016 è stato il commissario tecnico della nazionale italiana. Dal 2016 al 2018 ha allenato il Chelsea, club con cui ha vinto la Premier League 2016-2017 e la FA Cup 2017-2018.","strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"","strPosition":"Manager","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"","strYoutube":"","strHeight":"1.78 m (5 ft 10 in)","strWeight":"","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/kf63101679997162.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/2nxa881679997177.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/7ft4bd1679997221.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"Yes","strLocked":"unlocked","strLastName":"Conte"},{"idPlayer":"34236505","idTeam":"133670","idTeam2":null,"idTeamNational":null,"idAPIfootball":"347395","idPlayerManager":null,"idWikidata":null,"idTransferMkt":"703245","idESPN":"332411","strNationality":"Italy","strPlayer":"Antonio Vergara","strPlayerAlternate":"","strTeam":"Napoli","strTeam2":"","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"2003-01-16","dateDied":null,"strNumber":"26","dateSigned":null,"strSigning":"","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"Frattaminore, Italy","strEthnicity":"","strStatus":"","strDescriptionEN":null,"strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null