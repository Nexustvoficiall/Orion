cation":"São Paulo, Brazil","strEthnicity":"Hispanic","strStatus":"Active","strDescriptionEN":"Fagner Conserva Lemos (born 11 June 1989), simply known as Fagner, is a Brazilian professional footballer who plays as a right-back for Campeonato Brasileiro Série A club Cruzeiro, on loan for Corinthians.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"Right","strPosition":"Right-Back","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"","strYoutube":"","strHeight":"1.68 m (5 ft 6 in)","strWeight":"152 lbs","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/u4w22k1505671890.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/63czr61767454160.png","strCartoon":null,"strRender":"https://r2.thesportsdb.com/images/media/player/render/wrzk7q1562599274.png","strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Fagner"},{"idPlayer":"34169456","idTeam":"134294","idTeam2":null,"idTeamNational":null,"idAPIfootball":"10174","idPlayerManager":null,"idWikidata":"Q13646572","idTransferMkt":"244275","idESPN":"182522","strNationality":"Brazil","strPlayer":"Gabriel Barbosa","strPlayerAlternate":"Gabriel Barbosa Almeida","strTeam":"Cruzeiro","strTeam2":"","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"1996-08-30","dateDied":null,"strNumber":"9","dateSigned":null,"strSigning":"","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"São Bernardo do Campo, Brazil","strEthnicity":"Hispanic","strStatus":"Active","strDescriptionEN":"Gabriel Barbosa Almeida (born 30 August 1996), commonly known as Gabigol or Gabi, is a Brazilian professional footballer who plays as a forward for Campeonato Brasileiro Série A club Cruzeiro.\r\n\r\nA graduate of the Santos academy, Gabriel made his professional debut at the age of 16 and made over 200 appearances for the club across all competitions. Playing for Flamengo since 2019, he quickly became a fan favourite after scoring twice in the final minutes of the 2019 Copa Libertadores Final and again in the 2022 Copa Libertadores Final. After six seasons with Flamengo, he joined the fellow Brazilian club, Cruzeiro.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"Left","strPosition":"Centre-Forward","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"twitter.com/gabigol","strInstagram":"www.instagram.com/gabigol/","strYoutube":"","strHeight":"1.78 m (5 ft 10 in)","strWeight":"161 lbs","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/6bi4zh1578691323.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/yfna9l1767455650.png","strCartoon":null,"strRender":null,"strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Barbosa"},{"idPlayer":"34337133","idTeam":"134294","idTeam2":null,"idTeamNational":null,"idAPIfootball":"409849","idPlayerManager":null,"idWikidata":null,"idTransferMkt":null,"idESPN":null,"strNationality":"Brazil","strPlayer":"Janderson","strPlayerAlternate":"José Janderson da Silva Marques","strTeam":"Cruzeiro","strTeam2":"","strSport":"Soccer","intSoccerXMLTeamID":null,"dateBorn":"2005-08-31","dateDied":null,"strNumber":"32","dateSigned":null,"strSigning":"","strWage":"","strOutfitter":"","strKit":"","strAgent":"","strBirthLocation":"Altos, Brazil","strEthnicity":"Hispanic","strStatus":"Active","strDescriptionEN":"José Janderson da Silva Marques (born 31 August 2005), commonly known as Janderson, is a Brazilian footballer who plays for Cruzeiro. Mainly a centre-back, he can also play as a defensive midfielder.\r\n\r\nCareer\r\nBorn in Altos, Piauí, Janderson joined Fluminense-PI's youth sides in 2021. He made his first team debut in 2023, he was linked to a move to Corinthians in December of that year, but the deal fell through.\r\n\r\nOn 19 March 2024, Janderson was loaned to Cruzeiro and was assigned to the under-20 team. On 4 February of the following year, he was bought outright by the club, signing a three-year contract.\r\n\r\nJanderson made his Série A debut on 27 April 2025, coming on as a late substitute for Fagner in a 1–0 home win over Vasco da Gama.","strDescriptionDE":null,"strDescriptionFR":null,"strDescriptionCN":null,"strDescriptionIT":null,"strDescriptionJP":null,"strDescriptionRU":null,"strDescriptionES":null,"strDescriptionPT":null,"strDescriptionSE":null,"strDescriptionNL":null,"strDescriptionHU":null,"strDescriptionNO":null,"strDescriptionIL":null,"strDescriptionPL":null,"strGender":"Male","strSide":"Right","strPosition":"Centre-Back","strCollege":null,"strFacebook":"","strWebsite":"","strTwitter":"","strInstagram":"","strYoutube":"","strHeight":"190 cm","strWeight":"","intLoved":"0","strThumb":"https://r2.thesportsdb.com/images/media/player/thumb/v7fymc1767455955.jpg","strPoster":null,"strCutout":"https://r2.thesportsdb.com/images/media/player/cutout/j92cy11767456002.png","strCartoon":null,"strRender":null,"strBanner":null,"strFanart1":null,"strFanart2":null,"strFanart3":null,"strFanart4":null,"strCreativeCommons":"No","strLocked":"unlocked","strLastName":"Janderson"},{"idPlayer":"34295081","idTeam":"134294","idTeam2":null,"idTe